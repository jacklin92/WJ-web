---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
---

<BaseLayout>
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="max-w-2xl text-center">
      <p class="text-[var(--accent-light)] text-sm font-medium tracking-wider uppercase mb-4">
        歡迎來到我的作品集
      </p>
      <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-white via-[var(--accent-light)] to-[var(--accent)] bg-clip-text text-transparent leading-tight">
        {SITE_TITLE}
      </h1>
      <p class="text-lg text-[var(--text-secondary)] mb-8 leading-relaxed">
        我是一名網頁開發者，熱衷於打造互動式的網頁體驗。
        這裡是我的技術部落格與作品展示空間。
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="/blog"
          class="inline-block px-8 py-3 bg-[var(--accent)] hover:bg-[var(--accent-dark)] text-white rounded-lg font-medium transition-all hover:scale-105"
        >
          閱讀文章
        </a>
        <a
          href="https://github.com"
          target="_blank"
          class="inline-block px-8 py-3 border border-[var(--border-color)] hover:border-[var(--accent-light)] text-[var(--text-primary)] rounded-lg font-medium transition-all hover:scale-105"
        >
          GitHub
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
