---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThreeScene from '../components/ThreeScene.tsx';
import MouseGlow from '../components/MouseGlow.tsx';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('wj-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
        if (t === 'custom') {
          try {
            var c = JSON.parse(localStorage.getItem('wj-theme-custom') || '{}');
            if (c.baseMode === 'light') {
              document.documentElement.style.setProperty('--bg-primary', '#f5f5f7');
              document.documentElement.style.setProperty('--text-primary', '#1a1a2e');
            }
          } catch(e) {}
        }
      })();
    </script>
    <ThreeScene client:only="react" />
    <MouseGlow client:only="react" />
    <Header />
    <div class="relative z-10 pt-16">
      <slot />
    </div>
    <Footer />
  </body>
</html>
