---
const today = new Date();
---

<footer class="relative z-10 border-t border-[var(--border-color)] py-8 text-center bg-[var(--bg-primary)]/80 backdrop-blur-md">
  <p class="text-[var(--text-secondary)] text-sm m-0">
    &copy; {today.getFullYear()} My 3D Portfolio. All rights reserved.
  </p>
  <p class="text-[var(--text-secondary)] text-xs mt-2 m-0">
    Built with <a href="https://astro.build/" class="hover:text-white">Astro</a> +
    <a href="https://threejs.org/" class="hover:text-white">Three.js</a>
  </p>
</footer>
