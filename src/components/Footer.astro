---
const today = new Date();
---

<footer class="relative z-10 border-t border-[var(--border-color)] py-10 text-center bg-[var(--bg-primary)]/80 backdrop-blur-md">
  <div class="max-w-4xl mx-auto px-4">
    <div class="flex justify-center gap-4 mb-4">
      <a
        href="https://github.com/jacklin92"
        target="_blank"
        class="w-10 h-10 rounded-full border border-[var(--border-color)] flex items-center justify-center text-[var(--text-secondary)] hover:text-white hover:border-[var(--accent-light)] transition-all hover:scale-110"
      >
        <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
        </svg>
      </a>
    </div>
    <p class="text-[var(--text-secondary)] text-sm m-0">
      &copy; {today.getFullYear()} WJ. All rights reserved.
    </p>
    <p class="text-[var(--text-secondary)] text-xs mt-2 m-0">
      Built with
      <a href="https://astro.build/" class="hover:text-white transition-colors">Astro</a> +
      <a href="https://threejs.org/" class="hover:text-white transition-colors">Three.js</a> +
      <a href="https://react.dev/" class="hover:text-white transition-colors">React</a>
    </p>
  </div>
</footer>
