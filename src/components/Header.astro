---
import { SITE_TITLE } from '../consts';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300" style="backdrop-filter: blur(0px); background: transparent;">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <h2 class="text-lg font-bold m-0">
      <a href={`${basePath}/`} class="text-white no-underline hover:text-[var(--accent-light)] transition-colors flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-[var(--accent-light)]" style="box-shadow: 0 0 10px var(--accent-light);" />
        {SITE_TITLE}
      </a>
    </h2>
    <div class="flex gap-6 items-center">
      <a href={`${basePath}/`} class="nav-link text-[var(--text-secondary)] hover:text-white transition-colors text-sm font-medium relative">
        首頁
      </a>
      <a href={`${basePath}/blog`} class="nav-link text-[var(--text-secondary)] hover:text-white transition-colors text-sm font-medium relative">
        文章
      </a>
      <a
        href="https://github.com/jacklin92"
        target="_blank"
        class="text-[var(--text-secondary)] hover:text-white transition-all hover:scale-110"
      >
        <span class="sr-only">GitHub</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          />
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-light), var(--accent-glow));
    border-radius: 1px;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>

<script>
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (header) {
      if (window.scrollY > 50) {
        header.style.backdropFilter = 'blur(12px)';
        header.style.background = 'rgba(15, 15, 26, 0.8)';
        header.style.borderBottom = '1px solid var(--border-color)';
      } else {
        header.style.backdropFilter = 'blur(0px)';
        header.style.background = 'transparent';
        header.style.borderBottom = 'none';
      }
    }
  });
</script>
